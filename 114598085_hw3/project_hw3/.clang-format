Language: Cpp
BasedOnStyle: Google
Standard: c++20
AccessModifierOffset: -4
IndentWidth: 4
ColumnLimit: 80
AllowShortFunctionsOnASingleLine: Inline
DerivePointerAlignment: false
PointerAlignment: Left
IncludeBlocks: Regroup
IncludeCategories:
  # 1) Third-party / framework headers (angle-bracket with path separator).
  - Regex: '^<[^>]*[/.][^>]*>$'
    Priority: 1
  # 2) C/C++ standard library headers (angle-bracket, no path separator).
  - Regex: '^<.*>$'
    Priority: 2
  # 3) Project headers (quoted).
  - Regex: '^".*"'
    Priority: 3
SortIncludes: true
UseTab: Never
TabWidth: 4
BreakBeforeBraces: Custom
BraceWrapping:
  AfterFunction: false
  AfterClass: true
  AfterControlStatement: false
  AfterEnum: true
  AfterNamespace: true
  AfterStruct: true
  AfterUnion: true
  BeforeElse: true
  BeforeCatch: true
  IndentBraces: false